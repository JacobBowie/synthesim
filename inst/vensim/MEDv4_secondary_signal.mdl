{UTF-8}
adaptation=
	((adaptation rate*Signal)^2)/adaptation delay
	~	
	~		|

Fitness= INTEG (
	adaptation-atrophy,
		Baseline)
	~	 [0,?]
	~		|

adaptation rate=
	0.02
	~	
	~		|

volume load=
	81
	~	repetitions*RM/Week
	~		|

Baseline=
	12.145
	~	
	~		|

Fatigue= INTEG (
	TRIMP-Recovery,
		0)
	~	 [0,?]
	~		|

maximal fractional rate=
	0.029
	~	
	~		|

ROI=
	Fitness/frequency
	~	
	~		|

Recovery=
	(Fatigue/7)*EXP( 2 )
	~	
	~		|

Signal loss=
	(Signal^2)/14
	~	
	~		|

Signal= INTEG (
	TRIMP-adaptation-Signal loss,
		0)
	~	 [0,?]
	~		|

TRIMP=
	training
	~	
	~		|

fractional rate of atrophy=
	maximal fractional rate*Fitness over Capacity
	~	
	~		|

Capacity=
	200
	~	
	~		|

Fitness over Capacity=
	Fitness/Capacity
	~	 [0,1]
	~		|

frequency=
	3
	~	 [0,7,1]
	~		|

training=
	volume load*PULSE TRAIN(1, 1/7 , 1-frequency/7 , 16) +
	volume load*PULSE TRAIN( 17 , 1/7, 1-frequency/21 ,48 )
	~	
	~		|

adaptation delay=
	5
	~	1/Week [1,14,1]
	~		|

atrophy=
	ABS(muscle mass*fractional rate of atrophy)
	~	
	~		|

muscle mass=
	Fitness
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 48
	~	Week
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Week
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Week [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Week [0,?]
	~	The time step for the simulation.
	|

